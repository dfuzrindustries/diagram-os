{
  "version": "0.3.0",
  "colors": {
    "background":       "#F8F8F6",
    "sketchLine":       "#C8C4BC",
    "sketchDark":       "#3A3832",
    "accentPrimary":    "#7EC8A4",
    "accentSubtle":     "#C2E8D4",
    "surfacePanel":     "#FFFFFF",
    "surfaceAlt":       "#EDEBE7",
    "pillBackground":   "#F0F0EE",
    "connectorDefault": "#B0ABA3",
    "connectorActive":  "#7EC8A4",
    "labelMuted":       "#9A9590",

    "_brand_comment": "Intelligent Agency brand palette — slide 5, IntelleigentAgencyBrandIDfinalWIP.pdf",
    "brand": {
      "charcoal":    "#252930",
      "deepTeal":    "#1E4A57",
      "slate":       "#656578",
      "skyBlue":     "#6BA4C8",
      "mistBlue":    "#9EB3C4",
      "blazeOrange": "#E84E1B",
      "volt":        "#D4E100",
      "offWhite":    "#F1F3F1"
    }
  },
  "typography": {
    "fontFamily": "'Inter', system-ui, sans-serif",
    "roles": {
      "layerLabel":  { "size": "11pt", "weight": 700, "tracking": "200", "case": "upper" },
      "entityLabel": { "size": "9pt",  "weight": 500, "case": "title" },
      "relLabel":    { "size": "8pt",  "weight": 400, "case": "title" },
      "panelLabel":  { "size": "10pt", "weight": 700, "case": "title" },
      "detailText":  { "size": "7.5pt","weight": 400, "case": "sentence" },
      "diagramTitle":{ "size": "16pt", "weight": 700, "case": "title" }
    }
  },
  "serviceBand": {
    "_comment": "Config D flat service bands — see system.md Section 13A.",
    "fill":        "#1E4A57",
    "text":        "#F1F3F1",
    "height":      86,
    "chipFill":    "#6BA4C8",
    "chipText":    "#FFFFFF",
    "chipRadius":  5
  },
  "zone": {
    "_comment": "Labeled sub-region within a platform container — see system.md Section 13B.",
    "fill":        "#FFFFFF",
    "altFill":     "#EFF3F5",
    "border":      "#C8C4BC",
    "titleText":   "#1E4A57",
    "titleSize":   "8pt",
    "radius":      4
  },
  "dataChip": {
    "_comment": "Compact named item inside a zone or service band — see system.md Section 13C.",
    "fill":        "#6BA4C8",
    "text":        "#FFFFFF",
    "accentFill":  "#E84E1B",
    "specialFill": "#9EB3C4",
    "radius":      5
  },
  "dataMesh": {
    "_comment": "Config D hero platform container — flat with internal zones.",
    "containerFill":          "#F5F4F1",
    "containerBorder":        "#1E4A57",
    "containerBorderWeight":  2
  },
  "isometric": {
    "_comment": "One-point perspective model. See system.md Section 12A.",
    "vpYRatio":        -0.52,
    "gridStroke":      "#D0CCC4",
    "gridWeight":      0.4,
    "gridOpacity":     0.5,
    "gridRadialN":     8,
    "gridHorizN":      4,
    "edgeStripHeight": 13,
    "edgeStripFill":   "#EDEBE7",
    "relPillFill":     "#7EC8A4",
    "relPillText":     "#FFFFFF",
    "cascadeLines":    20,
    "cascadeCurveOffset": 30
  },
  "timeline": {
    "_comment": "Config E horizontal swimlane timeline — see system.md Section 14.",
    "activityFill":      "#6BA4C8",
    "deliverableFill":   "#E84E1B",
    "trackLabelColor":   "#1E4A57",
    "trackBarH":         28,
    "trackHeight":       80,
    "labelWidth":        152,
    "connectorColor":    "#B0ABA3",
    "connectorDash":     "5,3",
    "connectorWeight":   1.25,
    "gridMajorOpacity":  0.28,
    "gridMinorOpacity":  0.13,
    "phaseOpacity":      0.04,
    "todayColor":        "#E84E1B",
    "trackAccentColors": ["#1E4A57", "#6BA4C8", "#656578", "#9EB3C4"]
  },
  "rules": {
    "accentMaxCoverage":          0.20,
    "maxIconsPerPanel":           8,
    "maxAssetCardsPerDiagram":    1,
    "maxTypeSizesPerLayer":       2,
    "connectorLabelFormat":       "verb-form, max 2 words",
    "forbiddenColors":            ["red", "amber", "traffic-light conventions"],
    "brandAccentRule":            "brand.blazeOrange and brand.volt are permitted for brand expression and emphasis only — never as status/alert indicators. Status is communicated through weight and accent presence, not color semantics."
  }
}
